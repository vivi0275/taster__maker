SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# Shared OAuth token cache (recommended on Vercel — Upstash Redis)
# Create a free database at https://console.upstash.com
# Or connect Vercel KV — these aliases are also supported:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# YouTube Data API v3 (Live sets discovery)
# Accepted names: YOUTUBE_API_KEY or YOUTUBE_KEY
YOUTUBE_API_KEY=

# Last.fm (optional)
# Accepted names: LASTFM_API_KEY or LAST_KEY
LASTFM_API_KEY=

# PostHog analytics (optional — North Star: discovery_session_qualified)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
